{
  "name": "sonic",
  "private": true,
  "version": "0.2.0",
  "description": "Local-first intake, metadata, export, and library workstation for beat producers",
  "author": "Eternia Studios",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/eterniastudio/sonic",
  "repository": {
    "type": "git",
    "url": "https://github.com/eterniastudio/sonic.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "bundle:budget": "node scripts/check-bundle-budget.mjs",
    "check": "tsc --noEmit",
    "installer:smoke:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-smoke-test-installer.ps1",
    "media:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-media-engine-e2e.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "notices:npm": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-npm-notices.ps1",
    "notices:rust": "cargo fetch --locked --manifest-path src-tauri/Cargo.toml && cargo about generate --frozen --fail --all-features --manifest-path src-tauri/Cargo.toml --config about.toml --output-file artifacts/licenses/SONIC-RUST-THIRD-PARTY-LICENSES.html scripts/cargo-about.hbs",
    "notices:generate": "npm run notices:npm && npm run notices:rust",
    "release:prepare": "npm run build && npm run bundle:budget && npm run notices:generate",
    "tools:fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-tools.ps1",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "jsdom": "29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "4.1.10"
  }
}
