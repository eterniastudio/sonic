{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonic",
  "version": "0.1.4",
  "identifier": "studio.eternia.sonic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run release:prepare",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sonic - Beat Intake",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 650,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https://i.ytimg.com https://*.ytimg.com https://yt3.ggpht.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Eternia Studios",
    "copyright": "Copyright (c) 2026 Eternia Studios",
    "homepage": "https://github.com/eterniastudio/sonic",
    "licenseFile": "../LICENSE",
    "externalBin": ["binaries/python-runtime/python"],
    "resources": {
      "../LICENSE": "LICENSE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "../docs/ffmpeg-build-configuration.txt": "ffmpeg-build-configuration.txt",
      "../licenses/": "licenses/",
      "../artifacts/licenses/": "licenses/generated/",
      "../scripts/tool-manifest.json": "tool-manifest.json",
      "../scripts/install-media-engine.ps1": "install-media-engine.ps1",
      "binaries/python-runtime/*.dll": "",
      "binaries/python-runtime/*.pyd": "",
      "binaries/python-runtime/*.zip": "",
      "binaries/python-runtime/*.cat": "",
      "binaries/python-runtime/*._pth": "",
      "binaries/python-runtime/yt-dlp": "yt-dlp",
      "binaries/versions.json": "versions.json"
    },
    "shortDescription": "A local media intake and metadata tool for producers.",
    "longDescription": "Sonic downloads authorized beat references locally and extracts BPM, musical key, and tuning metadata for producers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
